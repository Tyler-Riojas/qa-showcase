<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Responsive Test Suite — Mobile" parallel="false" verbose="1">

    <listeners>
        <listener class-name="listeners.AnnotationTransformer"/>
        <listener class-name="listeners.TestListenerTestNG"/>
        <listener class-name="listeners.ExtentTestNGListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <!-- ========== MOBILE (iPhone 12 emulation) ========== -->
    <test name="Mobile (iPhone 12)">
        <parameter name="browser" value="chrome"/>
        <parameter name="device" value="IPHONE_12"/>
        <classes>
            <class name="TestNG.tests.ResponsiveTest"/>
        </classes>
    </test>

</suite>
