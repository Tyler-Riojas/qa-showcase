<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Kibeam Test Suite" parallel="false">

    <!-- Report Configuration -->
    <parameter name="reportName" value="Kibeam_UI_Tests"/>
    <parameter name="reportTitle" value="Kibeam UI Test Report"/>

    <listeners>
        <listener class-name="listeners.AnnotationTransformer"/>
        <listener class-name="listeners.TestListenerTestNG"/>
        <listener class-name="listeners.ExtentTestNGListener"/>
    </listeners>

    <test name="Kibeam Navigation Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="TestNG.tests.KibeamNavigationTest"/>
        </classes>
    </test>

    <test name="Kibeam Educators Page Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="TestNG.tests.KibeamEducatorsTest"/>
        </classes>
    </test>

    <test name="Kibeam Contact Page Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="TestNG.tests.KibeamContactTest"/>
        </classes>
    </test>

    <test name="Kibeam Responsive Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="TestNG.tests.KibeamResponsiveTest"/>
        </classes>
    </test>

</suite>
