<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Kibeam Device Emulation Suite" parallel="tests" thread-count="4">

    <!-- Report Configuration -->
    <parameter name="reportName" value="Device_Emulation_Tests"/>
    <parameter name="reportTitle" value="Kibeam Device Emulation Test Report"/>

    <listeners>
        <listener class-name="listeners.AnnotationTransformer"/>
        <listener class-name="listeners.TestListenerTestNG"/>
        <listener class-name="listeners.ExtentTestNGListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <!-- ========== MOBILE DEVICES ========== -->

    <test name="Kibeam Responsive - iPhone SE">
        <parameter name="browser" value="chrome"/>
        <parameter name="device" value="IPHONE_SE"/>
        <classes>
            <class name="TestNG.tests.KibeamResponsiveTest"/>
            <class name="TestNG.tests.KibeamNavigationTest"/>
        </classes>
    </test>

    <test name="Kibeam Responsive - iPhone 12">
        <parameter name="browser" value="chrome"/>
