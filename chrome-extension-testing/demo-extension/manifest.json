{
  "manifest_version": 3,
  "name": "QA Demo Extension",
  "version": "1.0.0",
  "description": "A minimal Chrome extension built for Selenium testing demonstration",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "QA Demo Extension"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_end"
  }]
}
