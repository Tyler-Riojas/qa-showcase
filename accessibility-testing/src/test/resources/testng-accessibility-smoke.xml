<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Accessibility Smoke" parallel="none" verbose="1">

    <!--
        Accessibility Smoke Suite
        =========================
        Quick CI check — runs only @Test(groups = {"smoke"}) methods.
        Single thread, fast, minimal memory footprint.

        Usage:
            mvn test -Paccessibility-smoke
            mvn test -Paccessibility-smoke -Dheadless=true
    -->

    <listeners>
        <listener class-name="listeners.AnnotationTransformer"/>
        <listener class-name="listeners.ExtentTestNGListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <parameter name="browser" value="chrome"/>

    <test name="Accessibility Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="TestNG.tests.GenericAccessibilityTest"/>
        </classes>
    </test>

</suite>
