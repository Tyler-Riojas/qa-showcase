<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Accessibility Tests" parallel="methods" thread-count="2" verbose="1">

    <!--
        Accessibility Test Suite
        ========================
        Runs full WCAG compliance scans using Axe-core and custom checks.

        thread-count=2 (not 4) — accessibility scans are memory intensive.
        Each scan holds violation data + DOM snapshots in memory.

        Usage:
            mvn test -Paccessibility
            mvn test -Paccessibility -Dtarget.url=https://yoursite.com
            mvn test -Paccessibility -Dheadless=true

        Memory note:
            If OutOfMemoryError occurs, add: export MAVEN_OPTS='-Xms512m -Xmx4096m'
    -->

    <listeners>
        <listener class-name="listeners.AnnotationTransformer"/>
        <listener class-name="listeners.ExtentTestNGListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <parameter name="browser" value="chrome"/>

    <test name="Generic Accessibility Tests">
        <classes>
            <class name="TestNG.tests.GenericAccessibilityTest"/>
        </classes>
    </test>

</suite>
