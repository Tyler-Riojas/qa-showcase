<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Device Performance" verbose="1">

    <!--
        Device Performance Suite
        ========================
        Tests page load times across 11 device/network profiles using
        Chrome DevTools Protocol emulation.

        Usage:
            mvn test -Pdevice-performance
            mvn test -Pdevice-performance -Dtarget.url=https://example.com
    -->

    <listeners>
        <listener class-name="listeners.AnnotationTransformer"/>
        <listener class-name="listeners.ExtentTestNGListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <parameter name="browser" value="chrome"/>

    <test name="Device Performance Tests">
        <classes>
            <class name="TestNG.tests.performance.DevicePerformanceTest"/>
        </classes>
    </test>

</suite>
