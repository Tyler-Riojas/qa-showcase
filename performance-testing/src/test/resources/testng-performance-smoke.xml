<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Performance Smoke" verbose="1">

    <!--
        Performance Smoke Suite
        =======================
        Runs UI and Network performance tests against the-internet.herokuapp.com.
        No Docker required.

        Usage:
            mvn test -Pperformance-smoke
            mvn test -Pperformance-smoke -Dheadless=true
    -->

    <listeners>
        <listener class-name="listeners.AnnotationTransformer"/>
        <listener class-name="listeners.ExtentTestNGListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <parameter name="browser" value="chrome"/>

    <test name="UI Performance Tests">
        <classes>
            <class name="TestNG.tests.performance.UIPerformanceTest"/>
        </classes>
    </test>

    <test name="Network Performance Tests">
        <classes>
            <class name="TestNG.tests.performance.NetworkPerformanceTest"/>
        </classes>
    </test>

</suite>
